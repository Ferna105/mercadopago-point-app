<resources>
    <!-- Base application theme. -->
    <style name="point_mainapp_demo_appTheme.main" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColor</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="colorSecondaryVariant">@color/secondaryDarkColor</item>
        <item name="colorOnSecondary">@color/primaryTextColor</item>
        <item name="android:statusBarColor">@color/barrita_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="textInputStyle">@style/point_mainapp_demo_appTheme.TextInputLayoutTheme</item>
        <item name="android:windowBackground">@color/barrita_yellow</item>
    </style>

    <style name="point_mainapp_demo_appTheme.TextInputLayoutTheme" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="colorControlNormal">@color/barrita_border</item>
        <item name="colorControlActivated">@color/barrita_teal</item>
        <item name="colorControlHighlight">@color/barrita_teal</item>
        <item name="android:textColorHint">@color/barrita_text_muted</item>
        <item name="startIconTint">@color/barrita_text_muted</item>
        <item name="hintTextColor">@color/barrita_text_muted</item>
        <item name="boxStrokeColor">@color/point_mainapp_demo_app_text_input_box_stroke</item>
    </style>

    <style name="point_mainapp_demo_appTheme.TextInputLayoutTheme.DropDown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="colorControlNormal">@color/barrita_border</item>
        <item name="colorControlActivated">@color/barrita_teal</item>
        <item name="colorControlHighlight">@color/barrita_teal</item>
        <item name="android:textColorHint">@color/barrita_text_muted</item>
        <item name="startIconTint">@color/barrita_text_muted</item>
        <item name="hintTextColor">@color/barrita_text_muted</item>
        <item name="boxStrokeColor">@color/point_mainapp_demo_app_text_input_box_stroke</item>
    </style>

    <style name="point_mainapp_demo_appTheme.TextInputLayoutTheme.errorAppearance" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/design_default_color_error</item>
    </style>

    <style name="point_mainapp_demo_appTheme.ButtonTheme.ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@android:color/white</item>
        <item name="backgroundTint">@color/barrita_teal</item>
        <item name="android:padding">@dimen/ui_2m</item>
        <item name="cornerRadius">@dimen/ui_9m</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="point_mainapp_demo_appTheme.ButtonTheme.ButtonSecondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/primaryTextColor</item>
        <item name="backgroundTint">@color/barrita_border</item>
        <item name="android:padding">@dimen/ui_2m</item>
        <item name="cornerRadius">@dimen/ui_9m</item>
        <item name="textAllCaps">false</item>
        <item name="iconTint">@color/primaryTextColor</item>
    </style>
</resources>
