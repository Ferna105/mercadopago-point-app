<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/barrita_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="40dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/point_mainapp_demo_app_stores_title"
            android:textColor="@color/barrita_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/point_mainapp_demo_app_stores_subtitle"
            android:textColor="@color/barrita_text_secondary"
            android:textSize="13sp" />

        <!-- Summary badges -->
        <LinearLayout
            android:id="@+id/point_mainapp_demo_app_my_stores_badges"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/point_mainapp_demo_app_badge_total"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:background="@drawable/point_mainapp_demo_app_summary_badge_total_bg"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textColor="@color/barrita_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="3 en total" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_badge_active"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/point_mainapp_demo_app_summary_badge_active_bg"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textColor="@color/barrita_teal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="2 habilitadas"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_badge_inactive"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/point_mainapp_demo_app_summary_badge_inactive_bg"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textColor="#737373"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="1 deshabilitada"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/point_mainapp_demo_app_my_stores_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Store list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/point_mainapp_demo_app_my_stores_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:visibility="gone"
        tools:listitem="@layout/point_mainapp_demo_app_item_store"
        tools:visibility="visible" />

    <!-- Empty -->
    <TextView
        android:id="@+id/point_mainapp_demo_app_my_stores_empty_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/point_mainapp_demo_app_home_no_stores"
        android:textColor="@color/barrita_text_secondary"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Error -->
    <TextView
        android:id="@+id/point_mainapp_demo_app_my_stores_error_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#DC2626"
        android:textSize="16sp"
        android:visibility="gone"
        tools:text="Error al cargar tiendas" />

</LinearLayout>
