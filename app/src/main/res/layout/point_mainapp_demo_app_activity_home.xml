<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryLightColor"
    android:padding="@dimen/ui_3m">

    <TextView
        android:id="@+id/point_mainapp_demo_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ui_5m"
        android:text="@string/point_mainapp_demo_app_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primaryTextColor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/point_mainapp_demo_app_user_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ui_2m"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        tools:text="usuario@email.com"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/point_mainapp_demo_app_title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/point_mainapp_demo_app_btn_my_stores"
        style="@style/point_mainapp_demo_appTheme.ButtonTheme.ButtonPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ui_5m"
        android:text="@string/point_mainapp_demo_app_home_btn_my_stores"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/point_mainapp_demo_app_user_email" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/point_mainapp_demo_app_btn_logout"
        style="@style/point_mainapp_demo_appTheme.ButtonTheme.ButtonSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ui_2m"
        android:text="@string/point_mainapp_demo_app_home_btn_logout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/point_mainapp_demo_app_btn_my_stores" />

</androidx.constraintlayout.widget.ConstraintLayout>
