<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="12dp"
    android:background="@drawable/point_mainapp_demo_app_closed_banner_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰"
        android:textSize="18sp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/point_mainapp_demo_app_store_closed"
            android:textColor="@color/barrita_amber_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/point_mainapp_demo_app_closed_banner_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/barrita_amber_text"
            android:textSize="12sp"
            tools:text="Horario de hoy: 10:00 - 22:00" />
    </LinearLayout>
</LinearLayout>
