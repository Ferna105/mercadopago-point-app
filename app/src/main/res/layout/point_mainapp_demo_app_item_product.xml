<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/barrita_card_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/barrita_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/point_mainapp_demo_app_product_image"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            tools:src="@drawable/point_mainapp_demo_app_store" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/point_mainapp_demo_app_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/barrita_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Café Americano" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_product_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/barrita_text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Café de filtro largo"
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/point_mainapp_demo_app_product_original_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:textColor="@color/barrita_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="$3.000"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/point_mainapp_demo_app_product_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/barrita_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="$2.500" />

                    <TextView
                        android:id="@+id/point_mainapp_demo_app_product_discount_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/point_mainapp_demo_app_badge_background"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:textColor="@color/barrita_teal"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="-20%"
                        tools:visibility="visible" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/point_mainapp_demo_app_product_add_to_cart"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/point_mainapp_demo_app_add_circle_bg"
                    android:contentDescription="@string/point_mainapp_demo_app_add_to_cart"
                    android:scaleType="centerInside"
                    android:src="@drawable/point_mainapp_demo_app_ic_plus" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
