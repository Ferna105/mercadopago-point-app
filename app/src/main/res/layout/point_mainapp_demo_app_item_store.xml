<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#F0EFED"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:orientation="vertical">

        <!-- Banner gradient -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="96dp">

            <View
                android:id="@+id/point_mainapp_demo_app_store_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Status badge -->
            <LinearLayout
                android:id="@+id/point_mainapp_demo_app_store_badge_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <View
                    android:id="@+id/point_mainapp_demo_app_store_badge_dot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/point_mainapp_demo_app_store_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="Abierta ahora" />
            </LinearLayout>
        </FrameLayout>

        <!-- Avatar overlapping area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false">

            <!-- Content with top padding for avatar overlap -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="32dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <!-- Name -->
                <TextView
                    android:id="@+id/point_mainapp_demo_app_store_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/barrita_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Mi Tienda" />

                <!-- Description -->
                <TextView
                    android:id="@+id/point_mainapp_demo_app_store_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/barrita_text_secondary"
                    android:textSize="12sp"
                    tools:text="Descripción de la tienda" />

                <!-- Schedule row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="7dp"
                        android:contentDescription="@null"
                        android:src="@drawable/point_mainapp_demo_app_ic_clock_small" />

                    <TextView
                        android:id="@+id/point_mainapp_demo_app_store_schedule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/barrita_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Lunes a Viernes: 10:00 - 22:00" />
                </LinearLayout>

                <!-- Payment method row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="7dp"
                        android:contentDescription="@null"
                        android:src="@drawable/point_mainapp_demo_app_ic_credit_card_small" />

                    <TextView
                        android:id="@+id/point_mainapp_demo_app_store_payment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/barrita_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Mercado Pago" />
                </LinearLayout>
            </LinearLayout>

            <!-- Avatar (overlaps banner) -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="20dp"
                android:layout_marginTop="-24dp"
                android:elevation="4dp">

                <!-- Initials fallback -->
                <TextView
                    android:id="@+id/point_mainapp_demo_app_store_avatar_initials"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/point_mainapp_demo_app_store_card_avatar_bg"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="MT"
                    tools:visibility="visible" />

                <!-- Store logo image -->
                <ImageView
                    android:id="@+id/point_mainapp_demo_app_store_avatar_image"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/point_mainapp_demo_app_store_card_avatar_bg"
                    android:clipToOutline="true"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:src="@drawable/point_mainapp_demo_app_store"
                    tools:visibility="visible" />
            </FrameLayout>
        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
