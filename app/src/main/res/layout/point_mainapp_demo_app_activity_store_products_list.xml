<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/barrita_background"
    tools:context=".view.storeproductslist.StoreProductsListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/point_mainapp_demo_app_store_products_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Error -->
        <TextView
            android:id="@+id/point_mainapp_demo_app_store_products_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="24dp"
            android:gravity="center"
            android:textColor="@color/barrita_text_secondary"
            android:visibility="gone"
            tools:text="Error al cargar"
            tools:visibility="visible" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/point_mainapp_demo_app_store_products_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="64dp"
            android:paddingBottom="64dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/point_mainapp_demo_app_empty_no_products"
                android:textColor="@color/barrita_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_empty_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/point_mainapp_demo_app_empty_no_products_sub"
                android:textColor="@color/barrita_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Product list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/point_mainapp_demo_app_store_products_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp"
            android:visibility="gone"
            tools:listitem="@layout/point_mainapp_demo_app_item_product"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Cart bottom bar (hidden when cart is empty) -->
    <LinearLayout
        android:id="@+id/point_mainapp_demo_app_cart_bar"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_gravity="bottom"
        android:background="@color/barrita_teal"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Left: cart icon + badge + trash -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/point_mainapp_demo_app_ic_cart" />

            <TextView
                android:id="@+id/point_mainapp_demo_app_cart_bar_count"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/point_mainapp_demo_app_cart_bar_badge_bg"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="3" />

            <ImageButton
                android:id="@+id/point_mainapp_demo_app_cart_bar_trash"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/point_mainapp_demo_app_cart_clear"
                android:scaleType="centerInside"
                android:src="@drawable/point_mainapp_demo_app_ic_trash" />
        </LinearLayout>

        <!-- Center: "Ver pedido" button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <TextView
                android:id="@+id/point_mainapp_demo_app_cart_bar_checkout"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:background="@drawable/point_mainapp_demo_app_cart_bar_btn_bg"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/point_mainapp_demo_app_cart_view_order"
                android:textColor="@color/barrita_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right: total price -->
        <TextView
            android:id="@+id/point_mainapp_demo_app_cart_bar_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="$12.500" />

    </LinearLayout>

</FrameLayout>
